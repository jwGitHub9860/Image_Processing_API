{
    "compilerOptions": {
        "target": "es2015",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "lib": ["ES6"],
        "allowJs": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "noImplicitAny": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "exclude": ["./dist", "spec", "eslint.config.mjs"]
}